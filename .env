DATABASE_URL=file:/home/z/my-project/db/custom.db

# Z-Image Bridge Service Configuration
# 模型来源: https://www.modelscope.cn/models/Tongyi-MAI/Z-Image/
# 运行模式: modelscope (推荐国内) | remote (HF Space) | api (HF API) | local (本地GPU)
ZIMAGE_MODE=modelscope
ZIMAGE_PORT=8001
ZIMAGE_SERVICE_URL=http://localhost:8001

# HuggingFace Token (api模式需要)
ZIMAGE_HF_TOKEN=

# ModelScope Token (可选，提升速率)
ZIMAGE_MS_TOKEN=

# 本地模型路径 (local模式使用)
ZIMAGE_LOCAL_MODEL=Tongyi-MAI/Z-Image
ZIMAGE_DEVICE=cuda
